{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "hardhat"],
    "skipLibCheck": true
  },
  "include": ["./hardhat.config.ts", "./src/**/*.ts", "./test/**/*.ts", "./typechain-types/**/*.ts"]
}
